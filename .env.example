# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
REDIS_URL=redis://localhost:6379

# ── API Keys (comma-separated) ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_KEYS=your-api-key-here,another-key-here

# ── Allowed browser origins (comma-separated) ─────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://ipinfo.hunterclipper.com,https://hunterclipper.com

# ── Intelligence API keys ──────────────────────────────────────────────────────
GEMINI_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
IPINFO_TOKEN=
PROXYCHECK_API_KEY=

# ── Cache & rate limits (optional, defaults shown) ────────────────────────────
SCAN_CACHE_TTL=21600        # 6 hours in seconds
RATE_LIMIT_WINDOW=3600      # 1 hour in seconds
RATE_LIMIT_LOOKUP=30        # max /lookup scans per IP per hour
RATE_LIMIT_ANALYZE=10       # max /analyze calls per IP per hour
